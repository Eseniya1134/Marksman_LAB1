<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<?import javafx.scene.layout.HBox?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.marksman.controller.MenuController"
           stylesheets="@marksman.css"
           id="menuRoot">
    <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="40">
        <children>

            <ImageView fx:id="heroImage"
                       fitWidth="220" fitHeight="220"
                       preserveRatio="true">
                <image>
                    <Image url="@/com/marksman/images/hero.png"/>
                </image>
            </ImageView>

            <VBox id="gameOverBox" alignment="CENTER" spacing="32">
                <Button fx:id="newGameBtn"
                        text="&#9654;  НАЧАТЬ ИГРУ"
                        styleClass="btn-pixel"
                        id="startBtn"
                        onAction="#onNewGameClick"/>

                <!-- Видна только если есть сохранение -->
                <Button fx:id="continueBtn"
                        text="&#8635;  ПРОДОЛЖИТЬ"
                        styleClass="btn-pixel"
                        id="continueBtn"
                        onAction="#onContinueClick"/>
            </VBox>

            <ImageView fx:id="targetImage"
                       fitWidth="220" fitHeight="220"
                       preserveRatio="true">
                <image>
                    <Image url="@/com/marksman/images/target.png"/>
                </image>
            </ImageView>

        </children>
    </HBox>
</StackPane>
